# SE2026 Monitoring Center - Apache rewrites

RewriteEngine On

# Redirect data/latest.json -> Supabase-backed API
# Supaya kode frontend (app.js / processor.js) yang masih panggil
# "data/latest.json" otomatis diarahkan ke Supabase Storage.
RewriteRule ^data/latest\.json$ api/history.php?action=latest-raw [L,QSA]

# Optional: rewrite data/history/YYYY-MM-DD.json (kalau ada akses langsung)
RewriteRule ^data/history/(\d{4}-\d{2}-\d{2})\.json$ api/history.php?action=get&date=$1 [L,QSA]

# Security: jangan ekspos .env
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Default index
DirectoryIndex index.php index.html
